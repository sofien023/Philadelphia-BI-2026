                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">WITH OFD_Filtre AS (
    SELECT 
        OF_Num, 
        Art_Code,
        date_creation
    FROM dim_ordrefab
),

Suivi AS (
    SELECT 
        ofs_num, 
        of_num,
        date_operation,   
        quantite
    FROM dim_ofsuivi
),

Composants AS (
    SELECT 
        OF_Num, 
        cmp_code, 
        quantite, 
        unite
    FROM dim_ofnomenclature
),

-- 🔹 Base calcul
BaseCalcul AS (
    SELECT 
        s.ofs_num,
        s.of_num,
        s.date_operation,
        o.Art_Code AS art_code,
        c.cmp_code,
        c.unite AS unite_qte,
        s.quantite * c.quantite AS Qte_Consommee,

        CASE c.unite
            WHEN 'KG' THEN 1000.0
            WHEN 'G'  THEN 1.0
            WHEN 'MG' THEN 0.001
            WHEN 'UN' THEN 1.0
            ELSE 1.0
        END AS Facteur_Qte

    FROM Suivi s
    JOIN OFD_Filtre o 
        ON s.of_num = o.of_num
    JOIN Composants c 
        ON s.of_num = c.of_num
),

-- 🔹 Prix résolu
PrixResolu AS (
    SELECT
        b.of_num,
        b.ofs_num,
        b.art_code,
        b.date_operation,
        b.cmp_code,
        b.unite_qte,
        b.Qte_Consommee,
        b.Facteur_Qte,

        p.prix,
        p.unite AS unite_prix,

        CASE p.unite
            WHEN 'KG'     THEN 0.001
            WHEN 'G'      THEN 1.0
            WHEN 'MG'     THEN 1000.0
            WHEN 'UN'     THEN 1.0
            WHEN '10UN'   THEN 0.1
            WHEN '1000UN' THEN 0.001
            ELSE 1.0
        END AS Facteur_Prix

    FROM BaseCalcul b

    OUTER APPLY (
        SELECT TOP 1 
            prix, 
            unite
        FROM dim_stock
        WHERE art_code = b.cmp_code
          AND prix IS NOT NULL
        ORDER BY
            CASE 
                WHEN date_prix &lt;= b.date_operation 
                THEN 0 
                ELSE 1 
            END,
            date_prix DESC
    ) p
)

SELECT
    date_operation AS DateKey,

    of_num,
    ofs_num,
    art_code,
    cmp_code,
    unite_qte,
    unite_prix,
    Qte_Consommee,
    prix,

    Qte_Consommee * Facteur_Qte AS Qte_Normalisee,

    prix * Facteur_Prix AS Prix_Normalise,

    Qte_Consommee
        * Facteur_Qte
        * prix
        * Facteur_Prix AS Cout_Ligne

FROM PrixResolu;</property>
