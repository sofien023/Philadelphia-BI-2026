      DTS:Namespace="User"
      DTS:ObjectName="LastRunDate">
      <DTS:VariableValue
        DTS:DataType="7">1/1/2000</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{874167C6-66DD-41F3-A568-943B1BF32F23}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="(DT_I4)(&#xA;  (DATEPART(&quot;yyyy&quot;, @[User::LastRunDate]) * 10000) +&#xA;  (DATEPART(&quot;mm&quot;, @[User::LastRunDate]) * 100) +&#xA;  DATEPART(&quot;dd&quot;, @[User::LastRunDate])&#xA;)"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="LastRunDateInt">
      <DTS:VariableValue
        DTS:DataType="3">20000101</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{EE1AFC53-129C-4DAA-A05A-8449AE8A9361}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;SELECT dd.Doc_Num, dd.Art_Code, dd.quantite, dd.prix_unitaire_HT&#xA;FROM dim_docDetails dd&#xA;INNER JOIN dim_document d ON dd.Doc_Num = d.Doc_Num&#xA;WHERE d.Date &gt;= &quot; + (DT_WSTR, 10) @[User::LastRunDateInt] +&#xA;&quot; ORDER BY dd.Doc_Num&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="SourceQueryDetails">
      <DTS:VariableValue
        DTS:DataType="8">SELECT dd.Doc_Num, dd.Art_Code, dd.quantite, dd.prix_unitaire_HT
FROM dim_docDetails dd
INNER JOIN dim_document d ON dd.Doc_Num = d.Doc_Num
WHERE d.Date &gt;= 20000101 ORDER BY dd.Doc_Num</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{CAE3CBBF-73BF-4485-93A6-1780A0C5CA20}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;SELECT Doc_Num, Date&#xA;FROM dim_document&#xA;WHERE Date &gt;= &quot; + (DT_WSTR, 10) @[User::LastRunDateInt] +&#xA;&quot; ORDER BY Doc_Num&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="SourceQueryDocument">
      <DTS:VariableValue
        DTS:DataType="8">SELECT Doc_Num, Date
FROM dim_document
WHERE Date &gt;= 20000101 ORDER BY Doc_Num</DTS:VariableValue>
    </DTS:Variable>
  </DTS:Variables>
