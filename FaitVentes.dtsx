                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">([SUBSTRING](#{Package\Data Flow Task\Merge Join.Outputs[Merge Join Output].Columns[Doc_Num]},1,1) == "A" ? (DT_R8)-1.0 : (DT_R8)1.0) * ((DT_R8)#{Package\Data Flow Task\Merge Join.Outputs[Merge Join Output].Columns[quantite]} * (DT_R8)#{Package\Data Flow Task\Merge Join.Outputs[Merge Join Output].Columns[prix_unitaire_HT]})</property>
