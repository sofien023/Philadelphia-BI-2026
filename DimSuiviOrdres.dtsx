                  <outputColumns>
                    <outputColumn
                      refId="Package\dimension document\Derived Column.Outputs[Derived Column Output].Columns[Derived Column 1]"
                      dataType="i4"
                      errorOrTruncationOperation="Computation"
                      errorRowDisposition="FailComponent"
                      lineageId="Package\dimension document\Derived Column.Outputs[Derived Column Output].Columns[Derived Column 1]"
                      name="Derived Column 1"
                      truncationRowDisposition="FailComponent">
                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">(DT_I4)(([YEAR](#{Package\dimension document\OLE DB Source.Outputs[OLE DB Source Output].Columns[OFS_Date]}) * 10000) + ([MONTH](#{Package\dimension document\OLE DB Source.Outputs[OLE DB Source Output].Columns[OFS_Date]}) * 100) + [DAY](#{Package\dimension document\OLE DB Source.Outputs[OLE DB Source Output].Columns[OFS_Date]}))</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">(DT_I4)((YEAR(OFS_Date) * 10000) + (MONTH(OFS_Date) * 100) + DAY(OFS_Date))</property>
                      </properties>
                    </outputColumn>
                  </outputColumns>
                  <externalMetadataColumns />
                </output>
