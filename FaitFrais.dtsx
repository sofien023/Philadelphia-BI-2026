                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT art_code, prix, unite AS unite_prix
FROM (
    SELECT art_code, prix, unite,
           ROW_NUMBER() OVER (
               PARTITION BY art_code
               ORDER BY date_prix DESC
           ) AS rn
    FROM dim_stock
    WHERE prix IS NOT NULL
) x
WHERE rn = 1
ORDER BY art_code</property>
