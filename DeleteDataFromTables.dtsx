    <DTS:Executable
      DTS:refId="Package\initial id"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{6395a4e5-df02-4803-9a1c-7a503f8768a0}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="initial id"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4BEAED95-F45E-4B35-BC7E-B2F8699C1B7D}"
          SQLTask:SqlStatementSource="-- ============================================&#xA;-- Reset IDENTITY seeds (run only when tables are empty)&#xA;-- ============================================&#xA;&#xA;-- 1. fait_ventes&#xA;IF (SELECT COUNT(*) FROM [dbo].[fait_ventes]) = 0&#xA;    DBCC CHECKIDENT ('[dbo].[fait_ventes]', RESEED, 0);&#xA;&#xA;-- 2. fait_fraisfab&#xA;IF (SELECT COUNT(*) FROM [dbo].[fait_fraisfab]) = 0&#xA;    DBCC CHECKIDENT ('[dbo].[fait_fraisfab]', RESEED, 0);&#xA;&#xA;-- 3. dim_stock&#xA;IF (SELECT COUNT(*) FROM [dbo].[dim_stock]) = 0&#xA;    DBCC CHECKIDENT ('[dbo].[dim_stock]', RESEED, 0);&#xA;&#xA;-- 4. dim_ofnomenclature&#xA;IF (SELECT COUNT(*) FROM [dbo].[dim_ofnomenclature]) = 0&#xA;    DBCC CHECKIDENT ('[dbo].[dim_ofnomenclature]', RESEED, 0);&#xA;&#xA;-- Verify all current identity values&#xA;SELECT &#xA;    OBJECT_NAME(OBJECT_ID)  AS table_name,&#xA;    last_value              AS current_identity,&#xA;    seed_value              AS seed,&#xA;    increment_value         AS increment&#xA;FROM sys.identity_columns&#xA;WHERE OBJECT_NAME(OBJECT_ID) IN (&#xA;    'fait_ventes',&#xA;    'fait_fraisfab',&#xA;    'dim_stock',&#xA;    'dim_ofnomenclature'&#xA;)&#xA;ORDER BY table_name;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
